---
import BaseLayout from '../layouts/BaseLayout.astro';
import SymptomChecker from '../components/SymptomChecker.jsx';
import AIPromptGenerator from '../components/AIPromptGenerator.jsx';
---

<BaseLayout title="Dashboard | Practical Podiatrist">
  <header class="mb-10 mt-8 text-center">
    <h1 class="text-4xl font-bold text-primary mb-2">Practical Podiatrist</h1>
    <p class="text-muted">Clinical Decision Support Dashboard</p>
  </header>

  <div class="grid gap-8">
    <section>
      <SymptomChecker client:load />
    </section>
    
    <section>
      <AIPromptGenerator client:load />
    </section>
  </div>
</BaseLayout>
