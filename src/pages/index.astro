---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Practical Podiatrist | Clear Foot Treatment Guides">
  <main class="max-w-4xl mx-auto px-6 py-20 text-slate-100 text-center">
    <span class="text-xs font-bold text-accent uppercase tracking-widest block mb-3">Welcome to Practical Podiatrist</span>
    <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">
      Honest, Field-Tested <span class="text-primary">Foot Care</span> Solutions.
    </h1>
    <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-12 leading-relaxed">
      No corporate retail pricing traps, no over-complicated clinical jargon. Just pure mechanical protocols to heal your feet right from your living room floor.
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <a href="/blog" class="px-8 py-4 bg-primary hover:bg-primary/90 text-white font-medium rounded-xl transition shadow-lg shadow-primary/20">
        📚 Browse Treatment Guides
      </a>
      <a href="/plantar-fasciitis" class="px-8 py-4 bg-slate-900 hover:bg-slate-800 text-slate-200 font-medium rounded-xl border border-white/10 transition">
        🦶 Plantar Fasciitis Guide
      </a>
    </div>
  </main>
</BaseLayout>
