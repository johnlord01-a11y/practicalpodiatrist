---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Practical Podiatrist | Better Foot & Ankle Health">
  <section class="max-w-4xl mx-auto px-6 pt-24 pb-16 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-teal-400/20 bg-teal-400/5 backdrop-blur-md text-slate-300 text-xs font-semibold uppercase tracking-wider mb-8 shadow-[0_0_20px_rgba(45,212,191,0.1)]">
      <span class="text-teal-400">✦</span> Evidence-Based • Practical • For Everyone
    </div>
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 text-white drop-shadow-xl">
      Better foot health.<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-400 to-blue-500">Made simple.</span>
    </h1>
    <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Practical tools and clear, research-backed guidance for anyone who wants healthier feet.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="#symptom-checker" class="px-8 py-4 bg-teal-400 hover:bg-teal-300 text-slate-950 font-bold rounded-xl transition-all shadow-[0_0_20px_rgba(45,212,191,0.3)] hover:shadow-[0_0_30px_rgba(45,212,191,0.5)] hover:-translate-y-1">
        Try the Symptom Checker
      </a>
      <a href="/blog" class="px-8 py-4 bg-white/5 hover:bg-white/10 backdrop-blur-xl text-slate-200 font-medium rounded-xl border border-white/10 transition-all hover:-translate-y-1">
        Browse Resources
      </a>
    </div>
  </section>

  <section id="symptom-checker" class="max-w-4xl mx-auto px-6 py-16 text-center">
    <h2 class="text-3xl font-bold text-white mb-2">Understand Your Symptoms</h2>
    <p class="text-slate-400 mb-10">Get clear, evidence-based insights in under a minute.</p>

    <div class="relative bg-white/[0.03] backdrop-blur-2xl border border-white/10 p-8 rounded-3xl shadow-[0_8px_32px_0_rgba(0,0,0,0.3)] max-w-3xl mx-auto text-left overflow-hidden">
      
      <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

      <h3 class="text-2xl font-semibold text-white mb-2 text-center drop-shadow-md">Interactive Visual Pain Guide</h3>
      <p class="text-slate-400 text-center mb-8 text-sm">Select a hotspot zone on the foot diagram, then tell us how your symptoms began.</p>
      
      <div class="border border-white/5 rounded-2xl p-6 bg-black/20 mb-6 flex flex-col items-center justify-center min-h-[250px] shadow-inner">
         <span class="text-slate-500 text-sm mb-6">Anatomical Target Map</span>
         <div class="flex flex-wrap justify-center gap-2 mb-8">
           <button class="px-4 py-1.5 bg-teal-400/20 text-teal-300 border border-teal-400/30 text-sm rounded-full font-medium shadow-[0_0_10px_rgba(45,212,191,0.2)]">Dorsal</button>
           <button class="px-4 py-1.5 bg-white/5 text-slate-300 text-sm rounded-full hover:bg-white/10 transition">Plantar</button>
           <button class="px-4 py-1.5 bg-white/5 text-slate-300 text-sm rounded-full hover:bg-white/10 transition">Medial</button>
         </div>
         <p class="text-teal-400 font-medium tracking-wide">Selected: Bottom of Heel</p>
      </div>

      <div class="space-y-3">
         <button class="w-full py-4 bg-white/5 border border-white/10 rounded-xl text-slate-200 hover:border-teal-400/50 hover:bg-white/10 transition-all text-sm text-left px-5 shadow-lg backdrop-blur-sm group">
            <span class="group-hover:scale-110 transition-transform inline-block">💥</span> An Injury or Trauma / Friction Blister
         </button>
         <button class="w-full py-4 bg-white/5 border border-white/10 rounded-xl text-slate-200 hover:border-teal-400/50 hover:bg-white/10 transition-all text-sm text-left px-5 shadow-lg backdrop-blur-sm group">
            <span class="group-hover:scale-110 transition-transform inline-block">⚡</span> Suddenly / Rapid Flaring & Itching
         </button>
      </div>
    </div>
  </section>
</BaseLayout>
