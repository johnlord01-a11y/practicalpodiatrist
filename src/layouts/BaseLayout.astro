---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-[#050810] text-slate-100 min-h-screen flex flex-col antialiased relative overflow-x-hidden">
    <div class="fixed inset-0 z-[-1] pointer-events-none">
      <div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] rounded-[40%_60%_70%_30%] bg-teal-500/10 blur-[120px] animate-orb"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[60%] h-[60%] rounded-[60%_40%_30%_70%] bg-blue-600/10 blur-[120px] animate-orb animation-delay-5000" style="animation-direction: reverse;"></div>
    </div>
    <Header />
    <div class="flex-grow z-10">
      <slot />
    </div>
    <Footer />
  </body>
</html>
