---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-[#0a0f1c] text-slate-100 min-h-screen flex flex-col antialiased">
    <Header />
    <div class="flex-grow">
      <slot />
    </div>
    <Footer />
  </body>
</html>
