<footer class="w-full bg-slate-950 border-t border-white/5 py-12 mt-20">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 text-sm">
    
    <!-- Subscription Column -->
    <div>
      <h4 class="font-semibold text-white mb-4 text-base">Stay Updated</h4>
      <p class="text-slate-400 mb-4">Get occasional clinical updates and new resources.</p>
      <form class="flex gap-2">
        <input type="email" placeholder="your@email.com" class="w-full bg-[#0a0f1c] border border-white/10 rounded-lg px-4 py-2 text-white focus:border-teal-400 focus:outline-none" />
        <button type="submit" class="bg-teal-400 hover:bg-teal-300 text-slate-950 font-semibold px-4 py-2 rounded-lg transition">Subscribe</button>
      </form>
    </div>

    <!-- Quick Links -->
    <div class="md:mx-auto">
      <h4 class="font-semibold text-white mb-4 text-base">Quick Links</h4>
      <ul class="space-y-3 text-slate-400">
        <li><a href="/blog" class="hover:text-teal-400 transition">Blog</a></li>
        <li><a href="/clinical-qa" class="hover:text-teal-400 transition">Clinical Q&A</a></li>
        <li><a href="/professionals" class="hover:text-teal-400 transition">For Medical Professionals</a></li>
      </ul>
    </div>

    <!-- Legal / Copyright -->
    <div class="text-slate-500 text-xs flex flex-col justify-end text-left md:text-right">
      <p class="mb-2">© 2026 Practical Podiatrist. All rights reserved.</p>
      <p>This site is for educational purposes only and is not a substitute for professional medical advice, diagnosis, or treatment.</p>
    </div>

  </div>
</footer>
